# .env.example — Local development for manual testing (scripts/test-payment.ts)
# Copy to .env and fill in real values. Never commit .env to git.
#
# Usage: npm run test:manual -- --name "John Smith" --amount 50.00

# Required
BASE_URL=http://localhost:8000
TOKEN=your_api_token_here

# Optional (defaults shown)
# VENMO_PAYMENT_GATEWAY_ID=25
# VENMO_EMAIL=venmo@venmo.com
# VENMO_USERNAME_CONTACT_FIELD=custom_value1  # Must be: custom_value1, custom_value2, custom_value3, or custom_value4
# LOG_LEVEL=info
