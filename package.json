{
  "name": "invoiceninja-payment-automation",
  "version": "2.0.0",
  "main": "dist/index.js",
  "author": "Derek Provance",
  "license": "ISC",
  "description": "Lambda that marks payments in invoice ninja",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "esbuild index.ts --bundle --minify --sourcemap --platform=node --target=es2022 --outfile=dist/index.js",
    "postbuild": "cd dist && zip -r index.zip index.js*",
    "compile": "npm run build",
    "format": "prettier --write \"**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:manual": "npx tsx scripts/test-payment.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.3.3",
    "dotenv": "^16.5.0",
    "esbuild": "^0.27.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
